      "id": "08e03859-af18-4a37-a36d-abb6ccd1af77",
      "name": "Read Existing IDs",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4,
      "position": [-752, 112],
      "alwaysOutputData": true
    },
    {
      "parameters": {
        "jsCode": "const existingRows = $('Read Existing IDs').all();\nconst inputData = $('Check Tab Exists').first().json;\nconst inputPosts = inputData.posts || [];\nconst existingIds = new Set(existingRows.map(row => String(row.json['Post ID'] || '')));\nconst newPosts = inputPosts.filter(post => !existingIds.has(String(post.postId)));\nif (newPosts.length === 0) {\n  return [{ json: { newPosts: [], hasNewPosts: false, sheetId: inputData.sheetId, tabName: inputData.tabName } }];\n}\nreturn [{ json: { newPosts, hasNewPosts: true, sheetId: inputData.sheetId, tabName: inputData.tabName } }];"
      },
      "id": "3f5e1eb0-d32b-4b22-bde3-6b717aa8aac2",
      "name": "Filter New Posts",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [-496, 112]
    },
    {
      "parameters": {
        "conditions": {
          "boolean": [
            {
              "value1": "={{ $json.hasNewPosts }}",
              "value2": true
            }
          ]
        }
      },
      "id": "50ea2329-e0bf-42a7-a4d5-bf487954f79d",
      "name": "IF Has New Posts",
      "type": "n8n-nodes-base.if",
      "typeVersion": 1,
      "position": [-256, 112]
    },
    {
      "parameters": {
        "jsCode": "const data = $input.first().json;\nconst posts = data.newPosts;\nconst scrapedAt = new Date().toISOString();\nreturn posts.map(post => ({\n  json: {\n    'Post ID': post.postId,\n    'Author': post.authorName,\n    'Post Link': post.postLink,\n    'Post Date': post.postDate,\n    'Scraped At': scrapedAt,\n    _sheetId: data.sheetId,\n    _tabName: data.tabName\n  }\n}));"
      },
      "id": "4e1bf9da-f36c-4a37-be21-12f5873e9e66",
      "name": "Build Rows",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [0, 0]
    },
    {
      "parameters": {
        "jsCode": "console.log('All posts already exist in sheet. Skipping append.');\nreturn [];"
      },
