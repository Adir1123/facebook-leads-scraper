        "nodeCredentialType": "googleSheetsOAuth2Api",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\"values\": [[\"Post ID\", \"Author\", \"Post Link\", \"Post Date\", \"Scraped At\"]]}",
        "options": {}
      },
