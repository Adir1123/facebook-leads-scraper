{
  "name": "leads_store_sheets",
  "nodes": [
    {
      "parameters": {},
      "id": "8bae16f4-6c05-4a64-a77b-fdf89f5ce3cf",
      "name": "Execute Workflow Trigger",
      "type": "n8n-nodes-base.executeWorkflowTrigger",
      "typeVersion": 1,
      "position": [-4096, 208]
    },
    {
      "parameters": {
        "jsCode": "const input = $input.first().json;\nconst posts = input.posts || [];\nconst groupUrl = input.group_url || '';\nif (posts.length === 0) {\n  return [{ json: { posts: [], groupUrl, tabName: '', sheetId: null, skip: true } }];\n}\nreturn [{ json: { posts, groupUrl } }];"
      },
      "id": "b17724f6-c165-4037-a208-67c866b4a562",
      "name": "Read Input",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [-3856, 208]
    },
    {
      "parameters": {
        "jsCode": "const groupUrl = $input.first().json.groupUrl;\nconst posts = $input.first().json.posts;\nconst match = groupUrl.match(/\\/groups\\/([^\\/\\?#]+)/);\nconst rawSlug = match ? match[1] : 'unknown-group';\nconst tabName = rawSlug\n  .replace(/[\\/\\\\?:*\\[\\]]/g, '-')\n  .replace(/-+/g, '-')\n  .replace(/^-|-$/g, '')\n  .substring(0, 100) || 'unknown-group';\nreturn [{ json: { posts, groupUrl, tabName } }];"
      },
      "id": "6475afe3-cd82-4ece-96a0-f7e0a3165004",
      "name": "Extract Tab Name",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [-3600, 208]
    },
    {
      "parameters": {
        "jsCode": "const staticData = $getWorkflowStaticData('global');\nconst posts = $input.first().json.posts;\nconst groupUrl = $input.first().json.groupUrl;\nconst tabName = $input.first().json.tabName;\nlet sheetId = staticData.sheetId || null;\nlet needsCreation = !sheetId;\nreturn [{ json: { sheetId, needsCreation, posts, groupUrl, tabName } }];"
      },
      "id": "0b37e6df-ab04-4600-8b3a-432b3cdc4b2b",
      "name": "Get or Create Sheet",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [-3344, 208]
    },
    {
      "parameters": {
        "conditions": {
          "boolean": [
            {
              "value1": "={{ $json.needsCreation }}",
              "value2": true
            }
          ]
        }
      },
      "id": "80f1ee88-c9a9-4fdb-a33a-4316c0147b23",
      "name": "IF Needs Sheet Creation",
      "type": "n8n-nodes-base.if",
      "typeVersion": 1,
      "position": [-3104, 208]
    },
    {
      "parameters": {
        "resource": "spreadsheet",
        "title": "Facebook Leads",
        "options": {}
      },
      "id": "11149fbe-bc53-44e9-9a31-dcfc132150fa",
      "name": "Create Spreadsheet",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4,
      "position": [-2848, 112]
    },
    {
      "parameters": {
        "operation": "share",
        "fileId": {
          "__rl": true,
          "value": "={{ $json.spreadsheetId }}",
          "mode": "id"
        },
        "permissionsUi": {
          "permissionsValues": {
            "role": "writer",
            "type": "user",
            "emailAddress": "adirgabay9@gmail.com"
          }
        },
        "options": {
          "sendNotificationEmail": false
        }
      },
      "id": "f8bab645-4877-49f8-9aeb-21e37a4cb632",
      "name": "Share Sheet",
      "type": "n8n-nodes-base.googleDrive",
      "typeVersion": 3,
      "position": [-2608, 112]
    },
    {
      "parameters": {
        "jsCode": "const staticData = $getWorkflowStaticData('global');\nconst newSheetId = $('Create Spreadsheet').first().json.spreadsheetId;\nstaticData.sheetId = newSheetId;\n// Try IF Needs Sheet Creation (normal path) then Self-Heal Sheet (recovery path)\nlet prev;\ntry {\n  prev = $('IF Needs Sheet Creation').first().json;\n} catch (e) {\n  prev = $('Self-Heal Sheet').first().json;\n}\nreturn [{ json: { sheetId: newSheetId, posts: prev.posts, groupUrl: prev.groupUrl, tabName: prev.tabName } }];"
      },
      "id": "23c3aad3-dd94-46dc-8130-fa6d40a6eb99",
      "name": "Store Sheet ID",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [-2352, 112]
    },
    {
      "parameters": {
        "jsCode": "const input = $('IF Needs Sheet Creation').first().json;\nreturn [{ json: { sheetId: input.sheetId, posts: input.posts, groupUrl: input.groupUrl, tabName: input.tabName } }];"
      },
      "id": "c5f9a235-b9d4-4b38-ad70-5d52a5bc670d",
      "name": "Pass Existing Sheet",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [-2848, 304]
    },
    {
      "parameters": {
        "url": "=https://sheets.googleapis.com/v4/spreadsheets/{{ $json.sheetId }}?fields=sheets.properties.title",
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "googleSheetsOAuth2Api",
        "options": {
          "response": {
            "response": {
              "neverError": true
            }
          }
        }
      },
      "id": "100926fe-76bd-43d5-9bd3-d6c179d84631",
      "name": "Validate Sheet Access",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4,
      "position": [-2096, 208],
      "onError": "continueErrorOutput"
    },
    {
      "parameters": {
        "jsCode": "// The HTTP response from Validate Sheet Access only has sheets[].properties.title\n// Recover sheetId, posts, groupUrl, tabName from the upstream Code nodes\n// that fed INTO Validate Sheet Access (Store Sheet ID or Pass Existing Sheet)\nconst httpResponse = $input.first().json;\n\n// Try Store Sheet ID first (creation path), fall back to Pass Existing Sheet (reuse path)\nlet upstream;\ntry {\n  upstream = $('Store Sheet ID').first().json;\n} catch (e) {\n  upstream = $('Pass Existing Sheet').first().json;\n}\n\nconst sheetId = upstream.sheetId;\nconst posts = upstream.posts;\nconst groupUrl = upstream.groupUrl;\nconst tabName = upstream.tabName;\n\n// Extract tab list from HTTP response\nconst tabs = (httpResponse.sheets || []).map(s => s.properties.title);\n\nreturn [{ json: { sheetId, posts, groupUrl, tabName, tabs } }];"
      },
      "id": "407906d5-3938-4502-9d9e-378e2028c4a5",
      "name": "Merge Validate Data",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [-1952, 112]
    },
    {
      "parameters": {
        "jsCode": "const staticData = $getWorkflowStaticData('global');\nconsole.log('Sheet ID ' + staticData.sheetId + ' is inaccessible (deleted or permissions revoked). Clearing static data and creating new sheet.');\nstaticData.sheetId = undefined;\n\n// Recover posts/groupUrl/tabName from upstream to pass through to creation branch\nlet upstream;\ntry {\n  upstream = $('Store Sheet ID').first().json;\n} catch (e) {\n  upstream = $('Pass Existing Sheet').first().json;\n}\n\n// Return with needsCreation flag — this output routes to Create Spreadsheet\nreturn [{ json: {\n  sheetId: null,\n  needsCreation: true,\n  posts: upstream.posts,\n  groupUrl: upstream.groupUrl,\n  tabName: upstream.tabName\n} }];"
      },
      "id": "0db83b56-500c-47a4-ab47-b0ef5c7603c1",
      "name": "Self-Heal Sheet",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [-1856, 304]
    },
    {
      "parameters": {
        "jsCode": "// Merge Validate Data has already recovered all upstream fields + tabs\nconst data = $input.first().json;\nconst tabExists = data.tabs.includes(data.tabName);\nreturn [{ json: { sheetId: data.sheetId, tabName: data.tabName, tabExists, posts: data.posts, groupUrl: data.groupUrl } }];"
      },
      "id": "8b83bdae-21d8-475b-8cd2-f41f8cd31b50",
      "name": "Check Tab Exists",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [-1744, 112]
    },
